{
  "port": 5714,
  "host": "localhost",
  "frontend_port": 3050,
  "debug": false,
  "default_per_page": 30,
  "cache_ttl_seconds": 300,
  "workflow_cache_ttl_minutes": 60,
  "workflow_cache_max_runs": 1000,
  "review_sample_limit": 250,
  "reviews_dir": "reviews",
  "default_repo": "scala-computing/scala",
  "agents": {
    "claude-opus": {
      "type": "claude_cli",
      "model": "claude-opus-4-6"
    },
    "claude-sonnet": {
      "type": "claude_cli",
      "model": "claude-sonnet-4-6"
    },
    "claude-haiku": {
      "type": "claude_cli",
      "model": "claude-haiku-4-5-20251001"
    },
    "openai": {
      "type": "openai_api",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY"
    },
    "cursor-opus": {
      "type": "cursor_cli",
      "model": "opus-4.6-thinking",
      "sandbox": "disabled"
    },
    "cursor-codex": {
      "type": "cursor_cli",
      "model": "gpt-5.3-codex-high",
      "sandbox": "disabled"
    },
    "cursor-codex-xh": {
      "type": "cursor_cli",
      "model": "gpt-5.4-xhigh",
      "sandbox": "disabled"
    }
  }
}
